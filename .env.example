# Supabase Configuration (client-side)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (alleen voor Netlify functions — NOOIT in de browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini API Key (Wordt automatisch afgehandeld in de preview, maar nodig voor eigen deployment)
GEMINI_API_KEY=
